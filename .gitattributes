# Normalize line endings on commit; check out platform-appropriate.
* text=auto eol=lf

# Source
*.cs       text diff=csharp
*.csproj   text eol=lf
*.props    text eol=lf
*.targets  text eol=lf
*.sln      text eol=crlf
*.slnx     text eol=lf

# Config
*.json     text eol=lf
*.yml      text eol=lf
*.yaml     text eol=lf
*.md       text eol=lf
*.editorconfig text eol=lf

# Scripts
*.sh       text eol=lf

# Binary
*.png      binary
*.jpg      binary
*.jpeg     binary
*.gif      binary
*.ico      binary
*.svg      binary
*.snk      binary
*.pfx      binary
*.nupkg    binary
*.snupkg   binary
